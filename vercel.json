{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-ynng.onrender.com/api/:path*"
    },
    {
      "source": "/voices/:path*",
      "destination": "https://backend-ynng.onrender.com/voices/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://backend-ynng.onrender.com/ws/:path*"
    },
    {
      "source": "/((?!api|voices|ws).*)",
      "destination": "/index.html"
    }
  ]
}
